{
  "name": "postboi",
  "version": "0.13.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postboi-mail/postboi.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "build:cli": "bun build ./src/cli/index.ts --target=node --outfile dist/cli.js",
    "prepack": "svelte-kit sync && svelte-package -i src/library && npm run build:cli && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.test.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.test.json --watch",
    "format": "oxfmt",
    "lint": "oxfmt --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "release": "bash scripts/release.sh"
  },
  "bin": {
    "postboi": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/postboi.js",
  "types": "./dist/postboi.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/postboi.d.ts",
      "svelte": "./dist/postboi.js",
      "default": "./dist/postboi.js"
    },
    "./zepto": {
      "types": "./dist/zepto.d.ts",
      "svelte": "./dist/zepto.js",
      "default": "./dist/zepto.js"
    },
    "./resend": {
      "types": "./dist/resend.d.ts",
      "default": "./dist/resend.js"
    },
    "./postmark": {
      "types": "./dist/postmark.d.ts",
      "default": "./dist/postmark.js"
    },
    "./sendgrid": {
      "types": "./dist/sendgrid.d.ts",
      "default": "./dist/sendgrid.js"
    },
    "./mailgun": {
      "types": "./dist/mailgun.d.ts",
      "default": "./dist/mailgun.js"
    },
    "./brevo": {
      "types": "./dist/brevo.d.ts",
      "default": "./dist/brevo.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "default": "./dist/cloudflare.js"
    },
    "./elasticemail": {
      "types": "./dist/elasticemail.d.ts",
      "default": "./dist/elasticemail.js"
    },
    "./mailersend": {
      "types": "./dist/mailersend.d.ts",
      "default": "./dist/mailersend.js"
    },
    "./mailjet": {
      "types": "./dist/mailjet.d.ts",
      "default": "./dist/mailjet.js"
    },
    "./sparkpost": {
      "types": "./dist/sparkpost.d.ts",
      "default": "./dist/sparkpost.js"
    },
    "./mandrill": {
      "types": "./dist/mandrill.d.ts",
      "default": "./dist/mandrill.js"
    },
    "./plunk": {
      "types": "./dist/plunk.d.ts",
      "default": "./dist/plunk.js"
    },
    "./mailtrap": {
      "types": "./dist/mailtrap.d.ts",
      "default": "./dist/mailtrap.js"
    },
    "./mailpace": {
      "types": "./dist/mailpace.d.ts",
      "default": "./dist/mailpace.js"
    },
    "./scaleway": {
      "types": "./dist/scaleway.d.ts",
      "default": "./dist/scaleway.js"
    },
    "./ses": {
      "types": "./dist/ses.d.ts",
      "default": "./dist/ses.js"
    },
    "./microsoft365": {
      "types": "./dist/microsoft365.d.ts",
      "default": "./dist/microsoft365.js"
    },
    "./smtp": {
      "types": "./dist/smtp.d.ts",
      "default": "./dist/smtp.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "default": "./dist/mock.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "default": "./dist/webhooks/index.js"
    },
    "./maizzle": {
      "types": "./dist/maizzle.d.ts",
      "default": "./dist/maizzle.js"
    },
    "./kit": {
      "types": "./dist/kit.d.ts",
      "svelte": "./dist/kit.js",
      "default": "./dist/kit.js"
    },
    "./svelte": {
      "types": "./dist/Captcha.svelte.d.ts",
      "svelte": "./dist/Captcha.svelte",
      "default": "./dist/Captcha.svelte"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "default": "./dist/vue.js"
    },
    "./astro": "./dist/Captcha.astro",
    "./form": {
      "types": "./dist/form.d.ts",
      "default": "./dist/form.js"
    }
  },
  "peerDependencies": {
    "@maizzle/framework": "^6.0.0",
    "@sveltejs/kit": "^2.0.0",
    "react": ">=18",
    "svelte": "^5.0.0",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "@maizzle/framework": {
      "optional": true
    },
    "@sveltejs/kit": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@maizzle/framework": "6.0.5",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "2.68.0",
    "@sveltejs/package": "2.5.8",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "@takumi-rs/image-response": "1.0.0-rc.12",
    "@types/hast": "^3.0.4",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/unist": "^3.0.3",
    "carbon-icons-svelte": "^13.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.20.0",
    "github-slugger": "^2.0.0",
    "globals": "17.7.0",
    "mdsvex": "^0.12.6",
    "oxfmt": "0.56.0",
    "publint": "0.3.21",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "shiki": "^4.0.1",
    "simple-icons": "^16.24.1",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "vue": "3.5.39",
    "wrangler": "^4.72.0"
  },
  "keywords": [
    "svelte"
  ]
}
