# Copy this file to `.env` — or let `bunx postboi init` write it for you.
#
# Put ONLY your chosen provider's secret(s) here. Which var(s) depends on the `provider`
# set in postboi.config.ts:
#
#   resend      RESEND_API_KEY
#   postmark    POSTMARK_SERVER_TOKEN
#   sendgrid    SENDGRID_API_KEY
#   brevo       BREVO_API_KEY
#   mailgun     MAILGUN_API_KEY
#   ses         AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
#   smtp        SMTP_PASS

RESEND_API_KEY=
