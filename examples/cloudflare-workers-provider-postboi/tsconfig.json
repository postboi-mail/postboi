{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Bundler",
		"moduleResolution": "Bundler",
		"lib": ["ES2022"],
		"types": ["@cloudflare/workers-types"],
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"moduleDetection": "force"
	},
	"include": ["src"]
}
